# OpenAI (used for receipt OCR via GPT-4o)
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here

# Google Cloud Document AI (optional, alternative OCR parser)
EXPO_PUBLIC_GOOGLE_PROJECT_ID=your_gcp_project_id
EXPO_PUBLIC_GOOGLE_LOCATION=us
EXPO_PUBLIC_GOOGLE_PROCESSOR_ID=your_document_ai_processor_id
EXPO_PUBLIC_GOOGLE_CLIENT_EMAIL=your_service_account@your_project.iam.gserviceaccount.com
EXPO_PUBLIC_GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase (for live bill sessions + web share links)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# Web base URL (where the Expo web build is hosted, e.g. Vercel)
EXPO_PUBLIC_WEB_BASE_URL=https://trydivi.vercel.app
