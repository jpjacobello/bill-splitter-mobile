rules_version = '2';

// Divi bill-splitting sessions.
// The app has no user accounts — a share link (containing an unguessable
// random Firestore document ID) IS the access credential. So we don't gate on
// request.auth; instead we constrain WHAT can be written, not WHO writes it.
service cloud.firestore {
  match /databases/{database}/documents {

    match /billSessions/{sessionId} {
      // Anyone with the link can load the bill.
      allow read: if true;

      // Anyone can create a session (creators have no account).
      // Must be a well-formed, open session that starts with no claims.
      allow create: if
        request.resource.data.status == 'open' &&
        request.resource.data.claims is map &&
        request.resource.data.keys().hasAll([
          'receipt', 'merchantName', 'creatorName',
          'createdAt', 'expiresAt', 'status', 'claims'
        ]);

      // Recipients may only add claims, the organizer may close it, and the
      // host's device may record the Live Activity push token. The receipt,
      // amounts, creator, and Venmo handle stay immutable — no one can tamper
      // with the bill or redirect payment.
      allow update: if
        // A closed bill is frozen: no reopening, no late claim edits, nothing.
        resource.data.status == 'open' &&
        request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(['claims', 'status', 'liveActivityPushToken']) &&
        request.resource.data.status in ['open', 'closed'] &&
        // Claims are append-only: existing claim entries can't be removed or
        // overwritten — an update may only add new keys.
        !request.resource.data.claims.diff(resource.data.claims)
          .affectedKeys().hasAny(resource.data.claims.keys());

      // Sessions are never deleted from the client (expiry handled app-side).
      allow delete: if false;
    }

    // Everything else is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
